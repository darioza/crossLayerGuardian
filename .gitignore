# =============================================================================
# CrossLayerGuardian — .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
dist/
build/
.eggs/
.Python
env/
venv/
.venv/
pip-log.txt

# =============================================================================
# Modelos treinados (arquivos grandes — depositar no Zenodo separadamente)
# =============================================================================
models/*.pkl
models/*.h5
models/*.h5f
models/*_metadata.json
models/*_components.pkl
models/training_log.csv
models/training_history.png

# Modelos de teste
Teste/*.pkl
Teste/file_collected_data.json

# =============================================================================
# Dados experimentais brutos (arquivos grandes)
# =============================================================================
data_collection/data/file_collected_data.json
data_collection/data/net_collected_data.json
data_collection/data/*.log

# =============================================================================
# Dependências externas (não são código do projeto)
# =============================================================================

# BCC framework completo (instalar via apt/pip)
data_collection/ebpf_programs/bcc/

# Kernel BTF headers auto-gerados pelo sistema local
# Gerar com: bpftool btf dump file /sys/kernel/btf/vmlinux format c > vmlinux.h
data_collection/ebpf_programs/vmlinux.h

# =============================================================================
# Build eBPF
# =============================================================================
*.o
*.d
*.ll

# =============================================================================
# Logs de execução
# =============================================================================
*.log
logs/
reports/

# =============================================================================
# OS / IDE
# =============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Jupyter (se usado para análise)
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# Variáveis de ambiente / segredos
# =============================================================================
.env
.env.*
secrets.ini
